# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Jupyter Notebooks
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# Virtual Environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# IDE / Editor configurations
.vscode/
.idea/
*.swp
*.swo

# Project specific ignores
# Ignore raw data since it contains massive CSV files from Kaggle
data/raw/*
!data/raw/.gitkeep

# Ignore processed data
data/processed/*
!data/processed/.gitkeep

# Ignore heavy ML model artifacts (they should be generated by pipelines, not committed to git)
artifacts/*.pkl
artifacts/*.csv
artifacts/*.png
artifacts/*.jpg

# Ignore logs
logs/*.log

# Operating system files
.DS_Store
Thumbs.db
